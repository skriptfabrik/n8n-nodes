{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/refs/heads/main/schemas/devContainer.base.schema.json",
  "name": "n8n-nodes",
  "image": "mcr.microsoft.com/vscode/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers-extra/features/mise:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers-extra/features/yamllint:2": {
      "version": "latest"
    },
    "ghcr.io/rocker-org/devcontainer-features/apt-packages:1": {
      "packages": "ghostscript,libcairo2-dev,libgif-dev,libjpeg-dev,libpango1.0-dev,librsvg2-dev"
    },
    "ghcr.io/skriptfabrik/devcontainer-features/yamlfix:1": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "christian-kohler.npm-intellisense",
        "davidanson.vscode-markdownlint",
        "dbaeumer.vscode-eslint",
        "editorconfig.editorconfig",
        "esbenp.prettier-vscode",
        "github.copilot",
        "github.vscode-github-actions",
        "github.vscode-pull-request-github",
        "hverlin.mise-vscode",
        "kuscamara.yamllint-fix",
        "ritwickdey.liveserver",
        "tamasfe.even-better-toml",
        "vercel.turbo-vsc"
      ],
      "settings": {
        "editor.defaultFormatter": "prettier.prettier-vscode",
        "[javascript]": {
          "editor.defaultFormatter": "prettier.prettier-vscode"
        }
      }
    }
  },
  "mounts": [
    {
      "source": "vscode-local-data",
      "target": "/home/vscode/.local",
      "type": "volume"
    }
  ],
  "containerEnv": {
    "MISE_TRUSTED_CONFIG_PATHS": "${containerWorkspaceFolder}"
  },
  "remoteEnv": {
    "DB_SQLITE_POOL_SIZE": "10",
    "GENERIC_TIMEZONE": "Europe/Berlin",
    "MISE_EXPERIMENTAL": "true",
    "MISE_LOCKFILE": "true",
    "N8N_DEV_RELOAD": "true",
    "N8N_DIAGNOSTICS_ENABLED": "false",
    "N8N_HIRING_BANNER_ENABLED": "false",
    "N8N_LOG_LEVEL": "debug",
    "N8N_PERSONALIZATION_ENABLED": "false",
    "N8N_RUNNERS_ENABLED": "true",
    "N8N_TEMPLATES_ENABLED": "false",
    "N8N_USER_FOLDER": "${containerWorkspaceFolder}",
    "N8N_VERSION_NOTIFICATIONS_ENABLED": "false",
    "TZ": "Europe/Berlin"
  },
  "onCreateCommand": ".devcontainer/hooks/on-create.sh",
  "postCreateCommand": ".devcontainer/hooks/post-create.sh"
}
