{
  "name": "@skriptfabrik/n8n-nodes-barcode",
  "version": "0.2.0",
  "description": "Barcode community nodes for n8n",
  "license": "MIT",
  "homepage": "https://github.com/skriptfabrik/n8n-nodes/blob/main/packages/barcode",
  "bugs": "https://github.com/skriptfabrik/n8n-nodes/issues",
  "keywords": [
    "barcode",
    "n8n",
    "n8n-community-node",
    "n8n-community-node-package"
  ],
  "author": {
    "name": "skriptfabrik",
    "email": "info@skriptfabrik.com"
  },
  "repository": "skriptfabrik/n8n-nodes.git",
  "scripts": {
    "build": "n8n-node build && pnpm -s exec esbuild dist/nodes/Barcode/Barcode.node.js --bundle --platform=node --format=cjs --target=node18 --external:n8n-workflow --outfile=dist/nodes/Barcode/Barcode.node.bundle.js && node -e \"require('node:fs').renameSync('dist/nodes/Barcode/Barcode.node.bundle.js','dist/nodes/Barcode/Barcode.node.js')\"",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev --external-n8n --custom-user-folder=$N8N_USER_FOLDER",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "test": "pnpm -s run build && node --test tests/**/*.test.cjs",
    "prepublishOnly": "n8n-node prerelease",
    "release": "semantic-release"
  },
  "files": [
    "dist/icons",
    "dist/nodes",
    "CHANGELOG.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [],
    "nodes": [
      "dist/nodes/Barcode/Barcode.node.js"
    ]
  },
  "devDependencies": {
    "bwip-js": "^4.7.0",
    "esbuild": "^0.27.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "publishConfig": {
    "access": "public"
  }
}
