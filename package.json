{
  "name": "@skriptfabrik/n8n-nodes",
  "version": "0.1.0",
  "description": "Community nodes for n8n",
  "private": true,
  "homepage": "https://github.com/skriptfabrik/n8n-nodes",
  "bugs": "https://github.com/skriptfabrik/n8n-nodes/issues",
  "keywords": [
    "n8n",
    "n8n-community-nodes"
  ],
  "author": {
    "name": "skriptfabrik",
    "email": "info@skriptfabrik.com"
  },
  "repository": "skriptfabrik/n8n-nodes.git",
  "scripts": {
    "build": "turbo build",
    "cloud:verify": "node tools/scripts/verify-cloud-readiness.mjs --all --retries 1 --delay-ms 0",
    "cloud:verify:package": "node tools/scripts/verify-cloud-readiness.mjs",
    "dev": "turbo dev",
    "fix:deps": "knip --fix",
    "fix:versions": "syncpack fix",
    "format:style": "prettier --write .",
    "format:versions": "syncpack format",
    "lint": "turbo lint",
    "lint:commits": "commitlint",
    "lint:deps": "knip",
    "lint:markdown": "markdownlint-cli2",
    "lint:style": "prettier --check .",
    "lint:versions": "syncpack lint",
    "n8n:owner:setup": "node tools/scripts/n8n-owner-setup.mjs",
    "n8n:start": "n8n start",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@n8n/node-cli": "^0.33.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "eslint": "^9.39.4",
    "knip": "^6.16.1",
    "markdownlint-cli2": "^0.22.1",
    "n8n": "^2.25.7",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "syncpack": "^15.3.1",
    "turbo": "^2.9.16",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
